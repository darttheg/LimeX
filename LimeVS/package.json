{
  "name": "lime-engine",
  "displayName": "Lime Engine",
  "publisher": "Lime",
  "description": "Build and run Lua-driven 3D applications.",
  "icon": "icon.png",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:lua"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lime.build",
        "title": "Lime: Build",
        "icon": "$(tools)"
      },
      {
        "command": "lime.run",
        "title": "Lime: Run",
        "icon": "$(play)"
      },
      {
        "command": "lime.buildAndRun",
        "title": "Lime: Build and Run",
        "icon": "$(play-circle)"
      },
      {
        "command": "lime.package",
        "title": "Lime: Package Project",
        "icon": "$(package)"
      },
      {
        "command": "lime.newProject",
        "title": "Lime: Create New Project",
        "icon": "$(new-folder)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lime.build",
          "group": "navigation@1"
        },
        {
          "command": "lime.run",
          "group": "navigation@2"
        },
        {
          "command": "lime.buildAndRun",
          "group": "navigation@3"
        },
        {
          "command": "lime.package",
          "group": "navigation@4"
        },
        {
          "command": "lime.newProject",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "Lime Engine",
      "properties": {}
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "win-version-info": "^6.0.1"
  }
}
